<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_insabhi_terms" model="ir.ui.view">
        <field name="name">res.config.settings.inherit.insabhi.terms</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sale.res_config_settings_view_form"/>
        <field name="priority" eval="30"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='catalog_setting_container']" position="inside">
                <setting string="Default Terms &amp; Conditions" help="Notes">
                    <field name="insabhi_note" widget="html" nolabel="1"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>