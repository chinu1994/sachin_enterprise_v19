<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="custom_saleorder_pdf_inherit" inherit_id="sale.report_saleorder_document">
        <xpath expr="//span[@t-field='doc.note']" position="before">
            <t t-if="doc.insabhi_term_condition and not is_html_empty(doc.insabhi_term_condition)">
                <div class="mt-4" style="margin-top: 25px;">
                    <strong style="font-size: 15px; text-decoration: underline;">
                        Bank Details
                    </strong>
                    <div style="margin-top: 10px; text-align: justify; line-height: 1.6; font-weight: bold;">
                        <t t-raw="doc.insabhi_term_condition"/>
                    </div>
                </div>
                <div style="height: 20px;"></div>
                <div>
                    <strong style="text-decoration: underline;">
                        Terms &amp; Conditions :-
                    </strong>
                </div>
            </t>
        </xpath>
         <xpath expr="//p[@t-if='not is_html_empty(doc.payment_term_id.note)']" position="replace">
             <t t-set="default_terms" t-value="env['ir.config_parameter'].sudo().get_param('insabhi.insabhi_note', default='')"/>
                <t t-if="default_terms and not is_html_empty(default_terms)">
                    <div style="margin-top:25px;">
                        <div style="line-height:1.6; text-align:justify;">
                            <t t-raw="default_terms"/>
                        </div>
                    </div>
                </t>
         </xpath>
    </template>
</odoo>