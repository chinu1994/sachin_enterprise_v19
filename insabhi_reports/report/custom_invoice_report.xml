<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="custom_invoice_report_template_paperformat" model="report.paperformat">
        <field name="name">Custom Invoice Report</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">10</field>
        <field name="margin_bottom">10</field>
        <field name="margin_left">10</field>
        <field name="margin_right">10</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">96</field>
    </record>
    <template id="custom_invoice_square_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.basic_layout">
                    <div class="page">
                        <t t-foreach="docs" t-as="doc">
                            <t t-foreach="doc.invoice_line_ids" t-as="line">
                                <div style="
                                    border:2px solid black;
                                    padding:15px;
                                    margin-bottom:15px;
                                    width:30%;
                                    float:left;
                                    margin-right:10px;
                                ">
                                    <div>
                                        <b>Inv :</b>
                                        <span t-esc="doc.name"/>
                                    </div>
                                    <div>
                                        <b>Product :</b>
                                        <span t-esc="line.product_id.name"/>
                                    </div>
                                    <div>
                                        <b>Qty :</b>
                                        <span t-esc="line.quantity"/>
                                    </div>
                                </div>
                            </t>
                        </t>
                    </div>
                </t>
            </t>
        </t>
    </template>
    <record id="action_custom_invoice_square_report" model="ir.actions.report">
        <field name="name">Custom Invoice Report</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">insabhi_reports.custom_invoice_square_template</field>
        <field name="report_file">insabhi_reports.custom_invoice_square_template</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="custom_invoice_report_template_paperformat"/>
        <field name="print_report_name">
            'Custom Report - %s' % (object.name)
        </field>
    </record>
</odoo>