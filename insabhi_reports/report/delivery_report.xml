<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="delivery_report_template_paperformat" model="report.paperformat">
        <field name="name">Delivery Report</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">10</field>
        <field name="margin_bottom">10</field>
        <field name="margin_left">10</field>
        <field name="margin_right">10</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">96</field>
    </record>
    <template id="report_delivery_yoga">
    <t t-call="web.html_container">
        <t t-foreach="docs" t-as="doc">

    <div class="page" style="font-family: Arial;">

        <!-- HEADER BAR -->
                <div style="
                    width: 100%;
                    padding-bottom: 8px;
                    margin-bottom: 10px;
                ">

                    <table style="width:100%;">
                        <tr>

                            <!-- LEFT SLOGAN -->
                            <td style="width:70%; vertical-align:middle;">
                                <div style="
                                    font-size:19px;
                                    font-weight:bold;
                                    font-style:italic;
                                    color:#333;
                                ">
                                    Pushing Aim Beyonds The Limits...
                                </div>
                            </td>

                            <!-- RIGHT LOGO -->
                            <td style="width:30%; text-align:right;">
                                <img t-if="doc.company_id.logo"
                                     t-att-src="image_data_uri(doc.company_id.logo)"
                                     style="max-height:65px;"/>
                            </td>

                        </tr>
                    </table>

                </div>


        <!-- COMPANY ADDRESS BLOCK -->
                        <div style="
                            font-size:13px;
                            line-height:18px;
                            margin-bottom:20px;
                            color:#444;
                        ">
                            <table style="width:100%; border-collapse:collapse;">

                                <tr>

                                    <!-- LEFT SIDE -->
                                    <td style="width:60%; vertical-align:top;">

                                        <!-- COMPANY NAME -->
                                        <div style="font-weight:bold;font-size:18px;" t-if="doc.company_id.name">
                                            <span t-esc="doc.company_id.name"/>
                                        </div>

                                        <br/>

                                        <!-- ADDRESS -->
                                        <div t-if="doc.company_id.street">

                                            <div style="display:flex; align-items:center;">
                                                <svg xmlns="http://www.w3.org/2000/svg"
                                                     width="14"
                                                     height="14"
                                                     viewBox="0 0 24 24"
                                                     fill="none"
                                                     stroke="currentColor"
                                                     stroke-width="2"
                                                     stroke-linecap="round"
                                                     stroke-linejoin="round"
                                                     style="margin-right:6px;">
                                                    <path d="M21 10c0 6-9 13-9 13S3 16 3 10a9 9 0 1 1 18 0z"></path>
                                                    <circle cx="12" cy="10" r="3"></circle>
                                                </svg>

                                                <span t-esc="doc.company_id.street"/>
                                            </div>

                                            <div style="padding-left:20px;" t-if="doc.company_id.city">
                                                <span t-esc="doc.company_id.city"/>
                                            </div>

                                            <div style="padding-left:20px;" t-if="doc.company_id.zip">
                                                <span t-esc="doc.company_id.zip"/>
                                            </div>

                                            <div style="padding-left:20px;" t-if="doc.company_id.country_id">
                                                <span t-esc="doc.company_id.country_id.name"/>
                                            </div>

                                        </div>

                                    </td>


                                    <!-- RIGHT SIDE -->
                                    <td style="width:40%; vertical-align:top; text-align:right;">
                                       <div style="
                                            font-weight:bold;
                                            font-size:15px;
                                            padding-right:86px;
                                            white-space:nowrap;
                                        ">
                                            ISO 9000:2015 UDYAM-MH-18-0012280
                                        </div><br/>
                                        <div t-if="doc.company_id.phone">
                                            <svg xmlns="http://www.w3.org/2000/svg"
                                                 width="14" height="14"
                                                 viewBox="0 0 24 24"
                                                 fill="none"
                                                 stroke="currentColor"
                                                 stroke-width="2"
                                                 stroke-linecap="round"
                                                 stroke-linejoin="round"
                                                 style="margin-right:6px;">

                                                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.08 4.18 2 2 0 0 1 4.06 2h3a2 2 0 0 1 2 1.72c.12.86.31 1.7.57 2.5a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.58-1.09a2 2 0 0 1 2.11-.45c.8.26 1.64.45 2.5.57A2 2 0 0 1 22 16.92z"/>
                                            </svg>
                                            <span t-esc="doc.company_id.phone"/>
                                        </div>

                                        <div t-if="doc.company_id.email">
                                            <svg xmlns="http://www.w3.org/2000/svg"
                                                 width="14" height="14"
                                                 viewBox="0 0 24 24"
                                                 fill="none"
                                                 stroke="currentColor"
                                                 stroke-width="2"
                                                 stroke-linecap="round"
                                                 stroke-linejoin="round"
                                                 style="margin-right:12px;">

                                                <path d="M4 4h16v16H4z"/>
                                                <path d="m22 6-10 7L2 6"/>
                                            </svg>
                                            <span style="padding-right: 80px;" t-esc="doc.company_id.email"/>
                                        </div>

                                        <div t-if="doc.company_id.website">
                                            <svg xmlns="http://www.w3.org/2000/svg"
                                                 width="14" height="14"
                                                 viewBox="0 0 24 24"
                                                 fill="none"
                                                 stroke="currentColor"
                                                 stroke-width="2"
                                                 stroke-linecap="round"
                                                 stroke-linejoin="round"
                                                 style="margin-right:10px;">

                                                <circle cx="12" cy="12" r="10"/>
                                                <path d="M2 12h20"/>
                                                <path d="M12 2a15 15 0 0 1 0 20a15 15 0 0 1 0-20"/>
                                            </svg>
                                            <span style="padding-right: 60px;" t-esc="doc.company_id.website"/>
                                        </div>

                                    </td>

                                </tr>

                            </table>

                        </div>

                         <!-- TITLE -->
                        <div style="text-align:center; margin-top:20px;">
                            <h2 style="margin:0; font-weight:bold;text-decoration: underline;">PACKING LIST</h2>

                        </div>
                        <div style="border:1px solid #000; padding:10px; margin-top:15px; font-size:13px; line-height:18px;">

                    <table style="width:100%; border-collapse:collapse;">

                        <!-- TOP ROW -->
                        <tr style="font-weight:bold;">

                            <!-- LEFT: Packing List -->
                            <td style="width:50%; text-align:left;">

                                <span t-if="doc.name">
                                    Packing List No : <span t-esc="doc.name"/>
                                </span>

                            </td>

                            <!-- RIGHT: Invoice -->
                            <td style="width: 50%;padding-left: 10px;">
                                Invoice No:
                                <t t-if="doc.sale_id and doc.sale_id.invoice_ids">
                                    <span t-esc="doc.sale_id.invoice_ids[0].name"/>
                                </t>
                                <t t-else="">
                                    -
                                </t>
                            </td>

                        </tr>
                        <!-- MAIN CONTENT -->
                        <tr>

                            <!-- LEFT BLOCK -->
                            <td style="vertical-align:top; width:50%;">
                             <div>
                                    <!-- CUSTOMER PO -->
                                <t t-if="doc.sale_id and doc.sale_id.client_order_ref">
                                    PO No. :
                                    <span t-esc="doc.sale_id.client_order_ref"/>
                                </t>
                                    <!-- SO NUMBER -->
                                    <t t-elif="doc.origin">
                                        SO No. :
                                        <span t-esc="doc.origin"/>
                                    </t>
                                    <!-- NOTHING -->
                                    <t t-else="">
                                        -
                                    </t>
                                </div>
                                <div>
                                    Date : <span t-if="doc.scheduled_date" t-esc="doc.scheduled_date"/>
                                </div>

                                <div>
                                    Job Sheet No. : <span t-if="doc.job_sheet_no" t-esc="doc.job_sheet_no"/>
                                </div>

                            </td>


                            <!-- RIGHT BLOCK -->
                            <td style="vertical-align:top; width:50%;padding-left:10px; position:relative;">
                                <div style="
                                    position:absolute;
                                    top:-30px;
                                    bottom:-11px;
                                    left:0;
                                    width:1px;
                                    background:#000;
                                "></div>
                                <div>
                                    Box No. : <span t-if="doc.box_no" t-esc="doc.box_no"/>
                                </div>

                                <div>
                                    Total Box : <span t-if="doc.total_box" t-esc="doc.total_box"/>
                                </div>

                                <div>
                                    Box Type : <span t-if="doc.box_type" t-esc="doc.box_type"/>
                                </div>

                                <div>
                                    Box Size : <span t-if="doc.box_size" t-esc="doc.box_size"/>
                                </div>
                            </td>
                        </tr>
                    </table>
                </div>
                        <table style="width:100%; border-collapse:collapse;margin-top:15px;" border="1">
                            <thead>
                        <tr style="background:#e6e6e6;">

                            <!-- SR NO -->
                            <th style="padding:8px; width:10%; text-align:center;">
                                Sr. No
                            </th>

                            <!-- DESCRIPTION -->
                            <th style="padding:8px; width:70%; text-align:left;">
                                Description
                            </th>

                            <!-- QUANTITY -->
                            <th style="padding:8px; width:20%; text-align:center;">
                                Quantity
                            </th>

                        </tr>
                    </thead>
                            <tbody>

                        <t t-set="count" t-value="1"/>

                        <t t-foreach="doc.move_ids" t-as="line">

                            <tr>

                                <!-- SR NO -->
                                <td style="padding:8px; text-align:center;">
                                    <span t-esc="count"/>
                                </td>

                                <!-- DESCRIPTION -->
                                <td style="padding:8px;">

                                    <t t-if="line.product_id.name">
                                        <span t-esc="line.product_id.name"/>
                                    </t>

                                    <t t-else="">
                                        -
                                    </t>

                                </td>

                                <!-- QUANTITY -->
                                <td style="padding:8px; text-align:center;">

                                    <t t-if="line.quantity">
                                        <span t-esc="line.quantity"/>
                                    </t>

                                    <t t-else="">
                                        0
                                    </t>

                                </td>

                            </tr>

                            <t t-set="count" t-value="count + 1"/>

                        </t>

                    </tbody>
                        </table>
                        <div style="
                            width:100%;
                            margin-top:25px;
                            font-size:13px;
                            line-height:22px;
                        ">
                        <div style="margin-bottom:20px;">
                            Assuring you of your best attention.Please go through the same and in case of any clarifications &amp; any discussion please feel free to contact us.
                        </div>
                        <table style="width:100%; border-collapse:collapse; margin-top:25px;">
                            <tr>
                                <!-- LEFT SIDE -->
                                <td style="width:50%; vertical-align:top;">
                                    <div style="margin-top:10px; font-weight:bold;">
                                        Checked By
                                    </div>
                                </td>
                                <!-- RIGHT SIDE -->
                                <td style="width:50%; vertical-align:top; text-align:left; padding-left:40px;">
                                    <div style="font-weight:bold; margin-bottom:10px;">
                                        Transport Details :
                                    </div>
                                </td>
                            </tr>
                        </table>
                    </div>
                    <div style="width:100%; margin-top:25px; overflow:hidden; font-size:13px;">

                        <!-- LEFT SIDE -->
                        <div style="width:50%; float:left;">
                            <div>
                                <b>Place :</b> Mumbai
                            </div>
                            <br/>
                            <div>
                                <b>Date :</b>
                                <span t-if="doc.scheduled_date"
                                  t-esc="doc.scheduled_date"/>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </t>
    </template>
    <record id="action_delivery_yoga_report" model="ir.actions.report">
        <field name="name">Delivery Report</field>
        <field name="model">stock.picking</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">insabhi_reports.report_delivery_yoga</field>
        <field name="report_file">insabhi_reports.report_delivery_yoga</field>
        <field name="binding_model_id" ref="stock.model_stock_picking"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="delivery_report_template_paperformat"/>
        <field name="print_report_name">
            'Delivery - %s' % (object.name)
        </field>
    </record>
</odoo>