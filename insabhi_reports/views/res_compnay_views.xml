<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_company_form_inherit_bank_details" model="ir.ui.view">
        <field name="name">res.company.form.inherit.bank.details</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='color']" position="after">
                <field name="bank_details" widget="text"/>
            </xpath>

        </field>
    </record>

</odoo>