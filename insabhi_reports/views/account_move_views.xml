<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="account_move_form_inherit_insabhi_po_no" model="ir.ui.view">
    <field name="name">account.move.form.inherit.insabhi</field>
    <field name="model">account.move</field>
    <field name="inherit_id" ref="account.view_move_form"/>
    <field name="arch" type="xml">
        <xpath expr="//field[@name='ref']" position="after">
            <field name="po_no"/>
        </xpath>
    </field>
</record>

     <record id="view_move_form_inherit_no_of_lebel" model="ir.ui.view">
        <field name="name">account.move.form.inherit.no_of_lebel</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_line_ids']//field[@name='quantity']" position="before">
                <field name="no_of_lebel" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>