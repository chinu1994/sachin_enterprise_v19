<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_inherit_partner_domain" model="ir.ui.view">
        <field name="name">account.move.form.partner.domain</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <!-- Computed domain field — invisible -->
            <xpath expr="//field[@name='partner_id']" position="before">
                <field name="partner_id_domain" invisible="1"/>
            </xpath>

            <!-- partner_id field pe domain apply -->
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="domain">partner_id_domain</attribute>
            </xpath>

        </field>
    </record>
</odoo>